---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '@valesordev/ui/SiteHeader.astro';
import SiteFooter from '@valesordev/ui/SiteFooter.astro';
import { getCollection } from 'astro:content';

const year = new Date().getFullYear();

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const talks = await getCollection('talks');
const activeTalks = talks.filter((t) => t.data.status !== 'delivered');
---

<Layout
  title="bashburn"
  description="Writing on observability, infrastructure, developer tooling, and conference talks in progress."
>
  <SiteHeader id="site-header">
    <div slot="logo">
      <a href="/" class="text-xl font-bold text-accent font-mono">~/bashburn</a>
    </div>
    <ul slot="nav" class="flex space-x-6 font-mono text-sm">
      <li><a href="/blog" class="text-muted hover:text-white transition-colors">blog</a></li>
      <li><a href="/talks" class="text-muted hover:text-white transition-colors">talks</a></li>
    </ul>
  </SiteHeader>

  <main class="pt-32 pb-20 px-4 max-w-3xl mx-auto">

    <!-- Intro -->
    <section class="mb-16">
      <p class="text-accent font-mono text-sm mb-3">$ whoami</p>
      <h1 class="text-3xl font-bold text-white mb-4">Brian</h1>
      <p class="text-muted leading-relaxed">
        I write about observability, infrastructure, and the developer tooling that makes everything
        feel fast. I'm also working on conference talks — this site is part of that process.
      </p>
    </section>

    <!-- Recent posts -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6">
        <p class="text-accent font-mono text-sm">$ ls blog/</p>
        <a href="/blog" class="text-muted hover:text-white text-sm transition-colors">all posts →</a>
      </div>
      {posts.length === 0 ? (
        <p class="text-muted">No posts yet. Coming soon.</p>
      ) : (
        <ul class="space-y-4">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}`} class="group block">
                <div class="flex items-baseline justify-between gap-4">
                  <span class="text-white group-hover:text-accent transition-colors font-medium">
                    {post.data.title}
                  </span>
                  <time class="text-muted text-sm shrink-0 font-mono">
                    {post.data.date.toISOString().slice(0, 10)}
                  </time>
                </div>
                <p class="text-muted text-sm mt-1">{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

    <!-- Talks in progress -->
    {activeTalks.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-6">
          <p class="text-accent font-mono text-sm">$ ls talks/ --filter=in-progress</p>
          <a href="/talks" class="text-muted hover:text-white text-sm transition-colors">all talks →</a>
        </div>
        <ul class="space-y-4">
          {activeTalks.map((talk) => (
            <li class="border border-border rounded-md p-4">
              <div class="flex items-start justify-between gap-4">
                <span class="text-white font-medium">{talk.data.title}</span>
                <span class={`text-xs font-mono px-2 py-0.5 rounded shrink-0 ${
                  talk.data.status === 'accepted' ? 'bg-green-900 text-green-300' :
                  talk.data.status === 'submitted' ? 'bg-yellow-900 text-yellow-300' :
                  'bg-surface text-muted'
                }`}>{talk.data.status}</span>
              </div>
              <p class="text-muted text-sm mt-2">{talk.data.abstract.slice(0, 160)}…</p>
            </li>
          ))}
        </ul>
      </section>
    )}

  </main>

  <SiteFooter>
    <div class="text-center font-mono text-sm">
      <p class="text-muted">&copy; {year} Brian · bashburn.com</p>
    </div>
  </SiteFooter>
</Layout>

<style>
  .text-accent { color: var(--color-accent); }
  .text-muted { color: var(--color-muted); }
  .border-border { border-color: var(--color-border); }
  .bg-surface { background: var(--color-surface); }
</style>

<script>
  import { initializeFaro, getWebInstrumentations } from '@grafana/faro-web-sdk';
  import { TracingInstrumentation } from '@grafana/faro-web-tracing';

  // TODO: Replace with bashburn.com Faro app URL from Grafana Cloud
